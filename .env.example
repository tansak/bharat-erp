# ─────────────────────────────────────────────────────────────────
# BHARAT ERP v6.0.0 — Environment Configuration
#
# LOCAL DEV:
#   cp .env.example .env
#   Fill in values, then: npm install && npm run seed && npm start
#
# RAILWAY DEPLOY:
#   Set these in Railway dashboard → your service → Variables tab.
#   Never commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (local)
MONGODB_URI=mongodb://localhost:27017/bharat_erp
# Production MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/bharat_erp?retryWrites=true&w=majority

# AI — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Auth — leave blank in dev; set strong random value in production
# Generate: openssl rand -hex 32
API_MASTER_KEY=

# CORS — * for dev; set your dashboard URL in production
ALLOWED_ORIGINS=*

# P2P Business Rules
AUTO_APPROVAL_LIMIT=100000
FRAUD_RISK_THRESHOLD=40
HIGH_VALUE_LIMIT=500000

# Sourcing Rules
MIN_RFQ_VENDORS=2
MAX_RFQ_VENDORS=5
RFQ_RESPONSE_DAYS=7

# HR / Payroll
COMPANY_ADDRESS=123 MG Road, Bengaluru 560001

# Multi-tenant default
DEFAULT_TENANT_ID=demo-corp

# WhatsApp (Sprint 3+) — platform runs in MOCK mode without these
# Twilio console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WA_FROM=whatsapp:+14155238886
FM_WHATSAPP_NUMBER=whatsapp:+919876543210
CFO_WHATSAPP_NUMBER=whatsapp:+919876543211
APPROVAL_TIMEOUT_HOURS=24
VALIDATE_TWILIO_SIG=false
